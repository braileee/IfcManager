<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Configurations>DebugRevit2022;DebugRevit2023;DebugRevit2024;DebugRevit2025;DebugRevit2026;ReleaseRevit2022;ReleaseRevit2023;ReleaseRevit2024;ReleaseRevit2025;ReleaseRevit2026;DebugRevit2026</Configurations>
		<OutputType>Library</OutputType>
		<UseWPF>true</UseWPF>
		<UseWindowsForms>true</UseWindowsForms>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)'=='DebugRevit2024' Or '$(Configuration)'=='ReleaseRevit2024' Or '$(Configuration)'=='ReleaseRevit2023' Or '$(Configuration)'=='DebugRevit2023' Or '$(Configuration)'=='DebugRevit2022' Or '$(Configuration)'=='ReleaseRevit2022'">
		<TargetFramework>net48</TargetFramework>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)'=='DebugRevit2025' Or '$(Configuration)'=='ReleaseRevit2025' Or '$(Configuration)'=='DebugRevit2026' Or '$(Configuration)'=='ReleaseRevit2026'">
		<TargetFramework>net8.0-windows</TargetFramework>
		<CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
	</PropertyGroup>

	<ItemGroup Condition="'$(Configuration)'=='DebugRevit2026' Or '$(Configuration)'=='ReleaseRevit2026'">
		<PackageReference Include="Revit_All_Main_Versions_API_x64" Version="2026.0.0">
			<IncludeAssets>compile</IncludeAssets>
			<PrivateAssets>all</PrivateAssets>
		</PackageReference>
		<PackageReference Include="Prism.Wpf" Version="8.1.97" />
		<PackageReference Include="NPOI" Version="2.5.6" />
	</ItemGroup>
	
	<ItemGroup Condition="'$(Configuration)'=='DebugRevit2025' Or '$(Configuration)'=='ReleaseRevit2025'">
		<PackageReference Include="Revit_All_Main_Versions_API_x64" Version="2025.0.0">
			<IncludeAssets>compile</IncludeAssets>
			<PrivateAssets>all</PrivateAssets>
		</PackageReference>
		<PackageReference Include="Prism.Wpf" Version="8.1.97" />
		<PackageReference Include="NPOI" Version="2.5.6" />
	</ItemGroup>
	
	<ItemGroup Condition="'$(Configuration)'=='DebugRevit2024' Or '$(Configuration)'=='ReleaseRevit2024'">
		<PackageReference Include="Revit_All_Main_Versions_API_x64" Version="2024.2.0">
			<IncludeAssets>compile</IncludeAssets>
			<PrivateAssets>all</PrivateAssets>
		</PackageReference>
		<PackageReference Include="Prism.Wpf" Version="8.1.97" />
	</ItemGroup>

	<ItemGroup Condition="'$(Configuration)'=='DebugRevit2023' Or '$(Configuration)'=='ReleaseRevit2023'">
		<PackageReference Include="Revit_All_Main_Versions_API_x64" Version="2023.0.0">
			<IncludeAssets>compile</IncludeAssets>
			<PrivateAssets>all</PrivateAssets>
		</PackageReference>
		<PackageReference Include="Prism.Wpf" Version="8.1.97" />
	</ItemGroup>

	<ItemGroup Condition="'$(Configuration)'=='DebugRevit2022' Or '$(Configuration)'=='ReleaseRevit2022'">
		<PackageReference Include="Revit_All_Main_Versions_API_x64" Version="2022.1.0">
			<IncludeAssets>compile</IncludeAssets>
			<PrivateAssets>all</PrivateAssets>
		</PackageReference>
		<PackageReference Include="Prism.Wpf" Version="8.1.97" />
	</ItemGroup>

	<ItemGroup>
		<None Remove="Resources\GenerateIfcMapping_32.png" />
		<None Remove="Resources\ParametersTagElements_32.png" />
		<None Remove="Resources\RevitIfcManagerExcelToRevit_32.png" />
	</ItemGroup>

	<ItemGroup>
		<Content Include="Resources\GenerateIfcMapping_32.png">
		  <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
		<Content Include="Resources\ParametersTagElements_32.png">
		  <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
		<Content Include="Resources\RevitIfcManagerExcelToRevit_32.png">
		  <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
		<Content Include="Resources\RevitIfcManagerSettings_32.png">
		  <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\RevitIfcManager.Core\RevitIfcManager.Core.csproj" />
	  <ProjectReference Include="..\RevitIfcManager.RevitApp\RevitIfcManager.RevitApp.csproj" />
	</ItemGroup>

	<Target Name="PostBuild" AfterTargets="PostBuildEvent">
		<Exec Command="if $(ConfigurationName) == DebugRevit2022 (&#xD;&#xA;xcopy &quot;$(TargetDir)*.*&quot; &quot;%25appdata%25\Autodesk\Revit\Addins\2022\$(ProjectName)\&quot; /y /s /e&#xD;&#xA;xcopy &quot;$(ProjectDir)Files\$(ProjectName).addin&quot; &quot;%25appdata%25\Autodesk\Revit\Addins\2022\&quot; /y)&#xD;&#xA;if $(ConfigurationName) == DebugRevit2023 (&#xD;&#xA;xcopy &quot;$(TargetDir)*.*&quot; &quot;%25appdata%25\Autodesk\Revit\Addins\2023\$(ProjectName)\&quot; /y /s /e&#xD;&#xA;xcopy &quot;$(ProjectDir)Files\$(ProjectName).addin&quot; &quot;%25appdata%25\Autodesk\Revit\Addins\2023\&quot; /y)&#xD;&#xA;if $(ConfigurationName) == DebugRevit2024 (&#xD;&#xA;xcopy &quot;$(TargetDir)*.*&quot; &quot;%25appdata%25\Autodesk\Revit\Addins\2024\$(ProjectName)\&quot; /y /s /e&#xD;&#xA;xcopy &quot;$(ProjectDir)Files\$(ProjectName).addin&quot; &quot;%25appdata%25\Autodesk\Revit\Addins\2024\&quot; /y)&#xD;&#xA;if $(ConfigurationName) == DebugRevit2025 (&#xD;&#xA;xcopy &quot;$(TargetDir)*.*&quot; &quot;%25appdata%25\Autodesk\Revit\Addins\2025\$(ProjectName)\&quot; /y /s /e&#xD;&#xA;xcopy &quot;$(ProjectDir)Files\$(ProjectName).addin&quot; &quot;%25appdata%25\Autodesk\Revit\Addins\2025\&quot; /y)&#xD;&#xA;if $(ConfigurationName) == DebugRevit2026 (&#xD;&#xA;xcopy &quot;$(TargetDir)*.*&quot; &quot;%25appdata%25\Autodesk\Revit\Addins\2026\$(ProjectName)\&quot; /y /s /e&#xD;&#xA;xcopy &quot;$(ProjectDir)Files\$(ProjectName).addin&quot; &quot;%25appdata%25\Autodesk\Revit\Addins\2026\&quot; /y)" />
	</Target>


</Project>
