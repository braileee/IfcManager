<UserControl x:Class="IfcManager.Settings.Views.MatchesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel>

        <!-- Toolbar -->

        <Border DockPanel.Dock="Top"
                BorderBrush="LightGray"
                BorderThickness="0,0,0,1"
                Padding="10">

            <StackPanel Orientation="Horizontal">

                <Button Content="Save"
                        Width="100"
                        Margin="0,0,5,0"
                        Command="{Binding SaveCommand}" />

                <Button Content="Add Match Table"
                        Width="150"
                        Command="{Binding AddMatchTableCommand}" />

            </StackPanel>

        </Border>

        <!-- Match Tables -->

        <TabControl ItemsSource="{Binding MatchTables}" x:Name="MatchTablesTabControl">

            <!-- Tab Header -->
            <TabControl.ItemTemplate>

                <DataTemplate>

                    <TextBlock Text="{Binding SheetPrefix}" />

                </DataTemplate>

            </TabControl.ItemTemplate>

            <!-- Tab Content -->
            <TabControl.ContentTemplate>

                <DataTemplate>

                    <DockPanel Margin="10">

                        <!-- Sheet Name -->

                        <StackPanel DockPanel.Dock="Top"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,10">

                            <TextBlock VerticalAlignment="Center"
                                       Text="Sheet:" />

                            <TextBox Width="250"
                                     Margin="5,0,0,0"
                                     Text="{Binding SheetPrefix,
                                            UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="5,0,0,0"
                                       VerticalAlignment="Center"
                                       Text=" Match" />

                            <Button Content="Delete Table"
                                    Margin="20,0,0,0"
                                    Width="120"
                                    Command="{Binding DataContext.RemoveMatchTableCommand,
                                                      ElementName=MatchTablesTabControl}"
                                    CommandParameter="{Binding}" />

                        </StackPanel>

                        <!-- Footer Buttons -->

                        <StackPanel DockPanel.Dock="Bottom"
                                    Orientation="Horizontal"
                                    Margin="0,10,0,0">

                            <Button Content="Add Property"
                                    Width="120"
                                    Margin="0,0,5,0"
                                    Command="{Binding AddSourcePropertyCommand}" />

                            <Button Content="Add Row"
                                    Width="120"
                                    Command="{Binding AddRowCommand}" />

                        </StackPanel>

                        <!-- Table -->

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">

                            <StackPanel>

                                <!-- Header Row -->

                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,5">

                                    <!-- Source Properties -->

                                    <ItemsControl ItemsSource="{Binding SourceProperties}">
                                        
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>

                                            <DataTemplate>

                                                <StackPanel Orientation="Horizontal">

                                                    <ComboBox Width="130"
                                                              Margin="2"
                                                              ItemsSource="{Binding AvailableProperties, UpdateSourceTrigger=PropertyChanged}"
                                                              SelectedItem="{Binding PropertyName, UpdateSourceTrigger=PropertyChanged}" />

                                                    <Button Width="20"
                                                            Height="22"
                                                            Margin="0,2,2,2"
                                                            Content="X"
                                                            Command="{Binding DataContext.RemoveSourcePropertyCommand,
                                                                               RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" />

                                                </StackPanel>

                                            </DataTemplate>

                                        </ItemsControl.ItemTemplate>

                                    </ItemsControl>

                                    <!-- Target Property -->

                                    <ComboBox Width="150"
                                              Margin="2"
                                              ItemsSource="{Binding AvailableProperties}"
                                              SelectedItem="{Binding TargetProperty,
                                                                    Mode=TwoWay,
                                                                    UpdateSourceTrigger=PropertyChanged}" />

                                    <!-- Action Header -->

                                    <Border Width="50"
                                            Margin="2"
                                            Padding="5"
                                            BorderBrush="Gray"
                                            BorderThickness="1">

                                        <TextBlock Text="Action"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center" />

                                    </Border>

                                </StackPanel>

                                <!-- Data Rows -->

                                <ItemsControl ItemsSource="{Binding Rows}">

                                    <ItemsControl.ItemTemplate>

                                        <DataTemplate>

                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,2">

                                                <!-- Criteria Values -->

                                                <ItemsControl ItemsSource="{Binding Criteria}">

                                                    <ItemsControl.ItemsPanel>

                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>

                                                    </ItemsControl.ItemsPanel>

                                                    <ItemsControl.ItemTemplate>

                                                        <DataTemplate>

                                                            <TextBox Width="150"
                                                                     Margin="2"
                                                                     Text="{Binding Value,
                                                                            UpdateSourceTrigger=PropertyChanged}" />

                                                        </DataTemplate>

                                                    </ItemsControl.ItemTemplate>

                                                </ItemsControl>

                                                <!-- Target Value -->

                                                <TextBox Width="180"
                                                         Margin="2"
                                                         Text="{Binding TargetValue,
                                                                UpdateSourceTrigger=PropertyChanged}" />

                                                <!-- Delete Row -->

                                                <Button Width="30"
                                                        Margin="2"
                                                        Content="X"
                                                        Command="{Binding DataContext.RemoveRowCommand,
                                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" />

                                            </StackPanel>

                                        </DataTemplate>

                                    </ItemsControl.ItemTemplate>

                                </ItemsControl>

                            </StackPanel>

                        </ScrollViewer>

                    </DockPanel>

                </DataTemplate>

            </TabControl.ContentTemplate>

        </TabControl>

    </DockPanel>

</UserControl>