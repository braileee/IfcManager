<UserControl  x:Class="IfcManager.Settings.Views.ComposedView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IfcManager.Settings.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
               x:Name="Root">
    <DockPanel Margin="10">

        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal">

            <Button Content="Add Property"
                    Margin="5"
                    Command="{Binding AddComposedPropertyCommand}" />

            <Button Content="Save"
                    Margin="5"
                    Command="{Binding SaveCommand}" />

        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <ItemsControl x:Name="ComposedPropertiesControl"
                ItemsSource="{Binding ComposedProperties, UpdateSourceTrigger=PropertyChanged}">

                <ItemsControl.ItemTemplate>

                    <DataTemplate>

                        <Border BorderThickness="1"
            BorderBrush="LightGray"
            Margin="3"
            Padding="4">

                            <StackPanel Orientation="Horizontal">

                                <!-- Composed Property -->

                                <Border BorderBrush="Gray"
                    BorderThickness="0,0,1,0"
                    Margin="0,0,10,0"
                    Padding="0,0,10,0">

                                    <StackPanel Orientation="Horizontal">

                                        <TextBlock Text="Property"
                               VerticalAlignment="Center"
                               Margin="0,0,5,0"/>

                                        <ComboBox Width="180"
                              Height="22"
                              DisplayMemberPath="PropertyName"
                              SelectedValuePath="PropertyName"
                              SelectedValue="{Binding Name}"
                              ItemsSource="{Binding DataContext.AvailableProperties,
                                             ElementName=Root}" />

                                        <Button Content="+ Segment"
                            Margin="5,0,0,0"
                            Height="22"
                            Padding="5,1"
                            Command="{Binding DataContext.AddSegmentCommand,
                                             ElementName=Root}"
                            CommandParameter="{Binding}" />

                                    </StackPanel>

                                </Border>

                                <!-- Formula -->

                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">

                                    <ItemsControl ItemsSource="{Binding Segments}">

                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>

                                            <DataTemplate>

                                                <StackPanel Orientation="Horizontal"
                                        Margin="1">

                                                    <TextBox Width="35"
                                         Height="22"
                                         Padding="2,0"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding Prefix,
                                                UpdateSourceTrigger=PropertyChanged}" />

                                                    <ComboBox Width="140"
                                          Height="22"
                                          Margin="1,0"
                                          DisplayMemberPath="PropertyName"
                                          SelectedValuePath="PropertyName"
                                          SelectedValue="{Binding SelectedProperty,
                                                UpdateSourceTrigger=PropertyChanged}"
                                          ItemsSource="{Binding DataContext.AvailableProperties,
                                                ElementName=Root}" />

                                                    <TextBox Width="25"
                                         Height="22"
                                         Padding="2,0"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding Suffix,
                                                UpdateSourceTrigger=PropertyChanged}" />

                                                    <Button Content="+"
                                                            Width="22"
                                                            Height="22"
                                                            Margin="1"
                                                            Command="{Binding DataContext.InsertSegmentAfterCommand,
                                                                      ElementName=ComposedPropertiesControl}"
                                                            CommandParameter="{Binding}" />

                                                    <Button Content="-"
                                                            Width="22"
                                                            Height="22"
                                                            Margin="1"
                                                            Command="{Binding DataContext.RemoveSegmentCommand,
                                                                      ElementName=ComposedPropertiesControl}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </DataTemplate>

                                        </ItemsControl.ItemTemplate>

                                    </ItemsControl>

                                </ScrollViewer>

                                <Button Content="Delete"
                    Margin="10,0,0,0"
                    Height="22"
                    Command="{Binding DataContext.DeleteComposedPropertyCommand,
                                     ElementName=Root}"
                    CommandParameter="{Binding}" />

                            </StackPanel>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </ScrollViewer>

    </DockPanel>
</UserControl>
