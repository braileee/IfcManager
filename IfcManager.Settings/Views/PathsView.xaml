<UserControl x:Class="IfcManager.Settings.Views.PathsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IfcManager.Settings.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel>
        <Label Content="Settings" Margin="2"/>

        <StackPanel Orientation="Horizontal">
            <TextBox IsEnabled="False" Text="{Binding SettingsFilePath}" 
                     Margin="2" 
                     Width="900"/>
            <Button Content="Load Settings" 
                    Margin="2"  
                    Command="{Binding LoadSettingsCommand}"
                    HorizontalAlignment="Left"
                    Width="100"/>
        </StackPanel>

        <Label Content="Source Excel (xlsx)" Margin="2"/>
        <StackPanel Orientation="Horizontal">
            <TextBox IsEnabled="False" Text="{Binding ExcelFilePath}" 
                     Margin="2" 
                     Width="900"/>
            <Button Content="Load Excel" 
                    Margin="2"  
                    Command="{Binding LoadExcelCommand}"
                    HorizontalAlignment="Left"
                    Width="100"/>
        </StackPanel>
    </StackPanel>
</UserControl>
