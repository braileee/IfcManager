	<KeyinHandlers>
		<KeyinHandler Keyin="MicrostationIfcManager LoadParameters" Function="MicrostationIfcManager.Keyins.LoadParameters"/>
		<KeyinHandler Keyin="MicrostationIfcManager TagElements" Function="MicrostationIfcManager.Keyins.TagElements"/>
		<KeyinHandler Keyin="MicrostationIfcManager ShowSettings" Function="MicrostationIfcManager.Keyins.ShowSettings"/>
	</KeyinHandlers>
</KeyinTree>